# Admin dashboard login (required in production — min 8 characters)
ADMIN_PASSWORD=your-strong-password-here
# Optional: separate secret for session cookies (recommended on Vercel)
ADMIN_SESSION_SECRET=generate-a-long-random-string

# Housing.com — from seller dashboard (Integrations / Webhook). Used to decrypt encrypted payloads.
HOUSING_PROFILE_ID=
HOUSING_ENCRYPTION_KEY=
# Optional: override pull API (default tries official URL from Housing docs)
# HOUSING_PULL_API_URL=https://housing.com/api/v1/leads/fetch

# Portal GAS URLs — update when Apps Script is redeployed (Housing webhook URL stays the same)
HOUSING_GAS_URL=https://script.google.com/macros/s/YOUR_HOUSING_DEPLOYMENT/exec
MAGICBRICKS_GAS_URL=https://script.google.com/macros/s/YOUR_MAGICBRICKS_DEPLOYMENT/exec

# Lead logs — use Supabase (recommended) OR optional Google Sheet logger
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional fallback if Supabase is not set
LOGS_GAS_URL=

# Optional: webhook URLs shown on dashboard home
VITE_PUBLIC_APP_URL=
