# Portal GAS URLs — update when Apps Script is redeployed (Housing webhook URL stays the same)
HOUSING_GAS_URL=https://script.google.com/macros/s/YOUR_HOUSING_DEPLOYMENT/exec
MAGICBRICKS_GAS_URL=https://script.google.com/macros/s/YOUR_MAGICBRICKS_DEPLOYMENT/exec

# Lead logs — use Supabase (recommended) OR optional Google Sheet logger
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional fallback if Supabase is not set
LOGS_GAS_URL=

# Optional: webhook URLs shown on dashboard home
VITE_PUBLIC_APP_URL=
